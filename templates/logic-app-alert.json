```json
{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workflows_la_app_secret_monitor_3_name": {
            "defaultValue": "la-app-secret-monitor-3",
            "type": "String"
        },
        "connections_acsemail_1_externalid": {
            "defaultValue": "/subscriptions/<Your Subscription ID>/resourceGroups/<Your Resource Group>/providers/Microsoft.Web/connections/<Your Connection Name>",
            "type": "String"
        }
    },
    "variables": {},
    "resources": [
        {
            "type": "Microsoft.Logic/workflows",
            "apiVersion": "2017-07-01",
            "name": "[parameters('workflows_la_app_secret_monitor_3_name')]",
            "location": "eastasia",
            "properties": {
                "state": "Enabled",
                "definition": {
                    "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
                    "contentVersion": "1.0.0.0",
                    "parameters": {
                        "$connections": {
                            "defaultValue": {},
                            "type": "Object"
                        }
                    },
                    "triggers": {
                        "Recurrence": {
                            "recurrence": {
                                "interval": 1,
                                "frequency": "Day",
                                "timeZone": "E. South America Standard Time",
                                "schedule": {
                                    "hours": [
                                        2
                                    ],
                                    "minutes": [
                                        0
                                    ]
                                }
                            },
                            "evaluatedRecurrence": {
                                "interval": 1,
                                "frequency": "Day",
                                "timeZone": "E. South America Standard Time",
                                "schedule": {
                                    "hours": [
                                        2
                                    ],
                                    "minutes": [
                                        0
                                    ]
                                }
                            },
                            "type": "Recurrence"
                        }
                    },
                    "actions": {
                        "Initialize_variables": {
                            "runAfter": {},
                            "type": "InitializeVariable",
                            "inputs": {
                                "variables": [
                                    {
                                        "name": "prefix",
                                        "type": "string",
                                        "value": "demo-"
                                    },
                                    {
                                        "name": "thresholdDays",
                                        "type": "integer",
                                        "value": 30
                                    },
                                    {
                                        "name": "tenantId",
                                        "type": "string",
                                        "value": "<Your Tenant ID>"
                                    },
                                    {
                                        "name": "clientId",
                                        "type": "string",
                                        "value": "<Your Client ID>"
                                    },
                                    {
                                        "name": "clientSecret",
                                        "type": "string",
                                        "value": "<Your Client Secret>"
                                    },
                                    {
                                        "name": "notifyTo",
                                        "type": "string",
                                        "value": "<Your Notification Email>"
                                    },
                                    {
                                        "name": "expiringItems",
                                        "type": "array"
                                    }
                                ]
                            }
                        },
                        "HTTP_Servidores": {
                            "runAfter": {
                                "Initialize_variables": [
                                    "Succeeded"
                                ]
                            },
                            "type": "Http",
                            "inputs": {
                                "uri": "https://graph.microsoft.com/v1.0/applications?$select=id,appId,displayName,passwordCredentials&$filter=startswith(displayName,'@{variables('prefix')}')&$count=true",
                                "method": "GET",
                                "headers": {
                                    "Accept": "application/json",
                                    "ConsistencyLevel": "eventual"
                                },
                                "authentication": {
                                    "type": "ActiveDirectoryOAuth",
                                    "authority": "https://login.microsoftonline.com",
                                    "tenant": "@{variables('tenantId')}",
                                    "audience": "https://graph.microsoft.com",
                                    "clientId": "@{variables('clientId')}",
                                    "secret": "@{variables('clientSecret')}"
                                }
                            },
                            "runtimeConfiguration": {
                                "contentTransfer": {
                                    "transferMode": "Chunked"
                                }
                            }
                        },
                        "Parse_JSON_Servidores": {
                            "runAfter": {
                                "HTTP_Servidores": [
                                    "Succeeded"
                                ]
                            },
                            "type": "ParseJson",
                            "inputs": {
                                "content": "@body('HTTP_Servidores')",
                                "schema": {
                                    "value": [
                                        {
                                            "id": "00000000-0000-0000-0000-000000000000",
                                            "appId": "00000000-0000-0000-0000-000000000000",
                                            "displayName": "demo-expiring-app-001",
                                            "passwordCredentials": [
                                                {
                                                    "displayName": "secret-1",
                                                    "keyId": "00000000-0000-0000-0000-000000000000",
                                                    "startDateTime": "2026-01-01T00:00:00Z",
                                                    "endDateTime": "2026-06-01T00:00:00Z"
                                                }
                                            ]
                                        }
                                    ]
                                }
                            }
                        },
                        "For_each_App": {
                            "foreach": "@body('Parse_JSON_Servidores')?['value']\n",
                            "actions": {
                                "For_each_client_secret": {
                                    "foreach": "@item()?['passwordCredentials']\n",
                                    "actions": {
                                        "Checa_Secrets_a_Expirar": {
                                            "actions": {
                                                "Compose_email_body": {
                                                    "type": "Compose",
                                                    "inputs": "<p><strong>Atenção: Client Secret próximo de expirar</strong></p>\n\n<p><strong>Aplicação:</strong> @{items('For_each_App')?['displayName']}</p>\n<p><strong>AppId:</strong> @{items('For_each_App')?['appId']}</p>\n\n<p><strong>Client Secret:</strong> @{items('For_each_client_secret')?['displayName']}</p>\n<p><strong>Hint:</strong> @{items('For_each_client_secret')?['hint']}</p>\n<p><strong>Data de expiração:</strong> @{items('For_each_client_secret')?['endDateTime']}</p>\n\n<p>Este secret expira em menos de 30 dias. Favor tomar as ações necessárias.</p>\n"
                                                },
                                                "Send_email": {
                                                    "runAfter": {
                                                        "Compose_email_body": [
                                                            "Succeeded"
                                                        ]
                                                    },
                                                    "type": "ApiConnection",
                                                    "inputs": {
                                                        "host": {
                                                            "connection": {
                                                                "name": "@parameters('$connections')['acsemail-1']['connectionId']"
                                                            }
                                                        },
                                                        "method": "post",
                                                        "body": {
                                                            "senderAddress": "<Your Sender Address>",
                                                            "recipients": {
                                                                "to": [
                                                                    {
                                                                        "address": "<Your Recipient Email>"
                                                                    }
                                                                ]
                                                            },
                                                            "content": {
                                                                "subject": "[ALERTA] Secret expira em menos de 30 dias - @{items('For_each_App')?['displayName']}\n",
                                                                "html": "<p class=\"editor-paragraph\">@{outputs('Compose_email_body')\n}</p>"
                                                            },
                                                            "importance": "High"
                                                        },
                                                        "path": "/emails:sendGAVersion",
                                                        "queries": {
                                                            "api-version": "2023-03-31"
                                                        }
                                                    }
                                                }
                                            },
                                            "runAfter": {
                                                "Compose_Debug": [
                                                    "Succeeded"
                                                ]
                                            },
                                            "else": {
                                                "actions": {}
                                            },
                                            "expression": {
                                                "and": [
                                                    {
                                                        "less": [
                                                            "@ticks(item()?['endDateTime'])",
                                                            "@ticks(addDays(utcNow(), 30))"
                                                        ]
                                                    }
                                                ]
                                            },
                                            "type": "If"
                                        },
                                        "Compose_Debug": {
                                            "type": "Compose",
                                            "inputs": "@item()\n"
                                        }
                                    },
                                    "type": "Foreach"
                                }
                            },
                            "runAfter": {
                                "Parse_JSON_Servidores": [
                                    "Succeeded"
                                ]
                            },
                            "type": "Foreach"
                        }
                    },
                    "outputs": {}
                },
                "parameters": {
                    "$connections": {
                        "value": {
                            "acsemail-1": {
                                "id": "/subscriptions/<Your Subscription ID>/providers/Microsoft.Web/locations/<Your Location>/managedApis/acsemail",
                                "connectionId": "[parameters('connections_acsemail_1_externalid')]",
                                "connectionName": "acsemail-1",
                                "connectionProperties": {}
                            }
                        }
                    }
                }
            }
        }
    ]
}
```
